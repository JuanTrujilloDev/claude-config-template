# Pre-filled answers for a FastAPI service (no frontend).
# Use: setup.sh --target /path/to/project --answers ./answers.env

project_name=My FastAPI Service
project_slug=my-fastapi-service
project_description=FastAPI backend service
language=Python
language_version=3.12+
backend_framework=FastAPI + Pydantic + SQLAlchemy
has_frontend=no
frontend_framework=
database=PostgreSQL
src_dir=src
tests_glob=tests/
frontend_dir=
format_cmd=ruff format . && ruff check --fix .
lint_cmd=ruff check . && mypy src/
test_cmd=pytest
build_cmd=uvicorn src.main:app --reload
test_coverage_target=85
line_length=100
formatter=ruff format
linter=ruff + mypy
branch_prefix=
ticket_tracker=GitHub
max_files_per_pr=12
max_loc_per_pr=3000
default_branch=main
has_celery=no
has_e2e=no
enforce_layer_split=no
