# Pre-filled answers for a Django + DRF + HTMX project.
# This is the closest match to the original 351 Exchange config.

project_name=My Django App
project_slug=my-django-app
project_description=Django + DRF + HTMX/Alpine.js hybrid app
language=Python
language_version=3.12+
backend_framework=Django + DRF
has_frontend=yes
frontend_framework=Django Templates + HTMX + Alpine.js + Tailwind
database=PostgreSQL
src_dir=apps
tests_glob=apps/**/tests/
frontend_dir=apps/frontend/
format_cmd=ruff check --fix . && black .
lint_cmd=ruff check . && pylint apps/
test_cmd=pytest
build_cmd=python manage.py runserver
test_coverage_target=85
line_length=90
formatter=black + ruff
linter=ruff + pylint
branch_prefix=PROJ
ticket_tracker=GitHub
max_files_per_pr=12
max_loc_per_pr=3000
default_branch=main
has_celery=yes
has_e2e=yes
enforce_layer_split=yes
